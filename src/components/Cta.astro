<section class="cta section" id="contact" data-theme-section="light">
  <h2 class="cta__title t-display t-display--xl" data-split>
    Let's build
  </h2>

  <p class="cta__sub t-body-lg" data-reveal>
    Tell us where to reach you and we'll start the conversation.
  </p>

  <form class="cta__form" data-contact-form novalidate>
    <!-- Honeypot: hidden from people, bots fill it and get dropped -->
    <input type="checkbox" name="botcheck" class="visually-hidden" tabindex="-1" autocomplete="off" aria-hidden="true" />

    <div class="cta__row">
      <label class="visually-hidden" for="cta-name">Your name</label>
      <input
        class="cta__input"
        id="cta-name"
        type="text"
        name="name"
        placeholder="Your name (optional)"
        autocomplete="name"
        maxlength="120"
        data-hover
      />
      <label class="visually-hidden" for="cta-email">Email address</label>
      <input
        class="cta__input"
        id="cta-email"
        type="email"
        name="email"
        placeholder="you@company.com"
        autocomplete="email"
        required
        data-hover
      />
    </div>

    <label class="visually-hidden" for="cta-message">What do you need?</label>
    <textarea
      class="cta__input cta__textarea"
      id="cta-message"
      name="message"
      placeholder="What do you need? A sentence is plenty. (optional)"
      rows="3"
      maxlength="2000"
      data-hover></textarea>

    <div class="cta__row cta__row--actions">
      <button class="cta__submit t-label" type="submit" data-hover>
        <span data-form-label>Send it</span>
      </button>
      <p class="cta__privacy">We only use this to reply to you. No lists, no spam.</p>
    </div>
    <p class="cta__status t-label" data-form-status role="status" aria-live="polite"></p>
  </form>
</section>

<style>
  .cta {
    min-height: 90svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .cta__title {
    color: var(--c-ink);
  }

  .cta__sub {
    margin-top: 2rem;
    max-width: 30rem;
    color: var(--c-ink-soft);
  }

  .cta__form {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 3rem;
    max-width: 38rem;
  }

  .cta__row {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .cta__row--actions {
    align-items: center;
    gap: 1.5rem;
  }

  .cta__privacy {
    font-size: 0.8rem;
    color: var(--c-ink-soft);
  }

  .cta__textarea {
    resize: vertical;
    border-radius: 1.25rem;
    min-height: 5.5rem;
    font-size: 0.95rem;
  }

  .cta__input {
    flex: 1 1 14rem;
    padding: 1.1rem 1.4rem;
    border: 1px solid var(--c-line);
    border-radius: 99px;
    background: var(--c-paper);
    color: var(--c-ink);
    transition: border-color 0.3s var(--ease-out-expo);
  }

  .cta__input::placeholder {
    color: var(--c-ink-soft);
  }

  .cta__input:focus {
    outline: none;
    border-color: var(--c-accent);
  }

  .cta__form.is-error .cta__input {
    border-color: #e23636;
  }

  .cta__submit {
    padding: 1.1rem 2.2rem;
    border-radius: 99px;
    background: var(--c-ink);
    color: var(--c-paper);
    transition:
      transform 0.35s var(--ease-out-expo),
      background-color 0.35s var(--ease-out-expo);
  }

  .cta__submit:hover {
    transform: scale(1.04);
    background: var(--c-accent);
  }

  .cta__submit:disabled {
    opacity: 0.6;
    transform: none;
  }

  .cta__status {
    flex-basis: 100%;
    min-height: 1.2em;
    color: var(--c-ink-soft);
  }

  .cta__form.is-error .cta__status {
    color: #e23636;
  }

  .cta__form.is-success .cta__status {
    color: #1d9e4b;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip-path: inset(50%);
    white-space: nowrap;
  }
</style>
