---
import SectionHead from "./SectionHead.astro";

const services = [
  {
    kind: "tasks",
    chip: "Workflow automation",
    title: "Automate the repetitive",
    blurb:
      "We map the busywork inside your operation — data entry, reporting, approval chains — and replace it with workflows that run themselves, around the clock.",
    tags: ["Task bots", "Back-office", "Reporting"],
  },
  {
    kind: "chat",
    chip: "AI agents",
    title: "Delegate the daily grind",
    blurb:
      "From triaging inboxes to drafting documents and summarizing meetings, our agents live inside your tools and work your rules — without the handholding.",
    tags: ["Summaries", "Scheduling", "Research"],
  },
  {
    kind: "build",
    chip: "AI products",
    title: "Ship AI-native product",
    blurb:
      "From a napkin sketch to production: we design, prototype and launch AI products with real interfaces, real users and real stakes.",
    tags: ["Prototype", "Interface", "Launch"],
  },
  {
    kind: "dash",
    chip: "Strategy & custom",
    title: "Build smarter systems",
    blurb:
      "Starting from scratch or upgrading what you have, we bring strategic consulting and custom builds aligned with where your business is actually going.",
    tags: ["Audit", "Roadmap", "Consulting"],
  },
];
---

<section class="services section" id="services" data-theme-section="light">
  <SectionHead
    chip="Our services"
    title='AI that does the work, not the <em class="t-tilt">talking</em>'
    sub="Automation, agents and product, designed and shipped for the stack you already run."
  />

  <ul class="services__list">
    {
      services.map((s) => (
        <li class="feat" data-service-row>
          <div class="feat__text">
            <span class="feat__chip t-label">{s.chip}</span>
            <h3 class="feat__title t-display t-display--md">{s.title}</h3>
            <p class="feat__body">{s.blurb}</p>
            <ul class="feat__tags" role="list">
              {s.tags.map((t) => (
                <li class="t-label">{t}</li>
              ))}
            </ul>
          </div>

          <div class="feat__visual" aria-hidden="true">
            {s.kind === "tasks" && (
              <div class="mock mock--tasks">
                <div class="mock__bar">All tasks</div>
                <div class="mock__row">
                  <span class="mock__check mock__check--done" />
                  <span>
                    Payment reminders <small>sent to 42 clients</small>
                  </span>
                </div>
                <div class="mock__row mock__row--hot">
                  <span class="mock__check mock__check--done" />
                  <span>
                    Weekly report <small>generated &amp; shared</small>
                  </span>
                </div>
                <div class="mock__row">
                  <span class="mock__check" />
                  <span>
                    Invoice approvals <small>2 waiting</small>
                  </span>
                </div>
              </div>
            )}
            {s.kind === "chat" && (
              <div class="mock mock--chat">
                <span class="mock__orb" />
                <p class="mock__q">What can I take off your plate?</p>
                <div class="mock__input"><span class="mock__type">Summarize this morning's standup…</span></div>
                <div class="mock__chips">
                  <span>Draft</span>
                  <span>Schedule</span>
                  <span>Research</span>
                </div>
              </div>
            )}
            {s.kind === "build" && (
              <div class="mock mock--build">
                <div class="mock__dots">
                  <i /><i /><i />
                </div>
                <div class="mock__code">
                  <span style="width: 62%" />
                  <span style="width: 84%" class="mock__code--accent" />
                  <span style="width: 48%" />
                  <span style="width: 71%" />
                  <span style="width: 35%" class="mock__code--accent" />
                </div>
                <div class="mock__deploy">● Deployed to production</div>
              </div>
            )}
            {s.kind === "dash" && (
              <div class="mock mock--dash">
                <div class="mock__stat">
                  <span>Hours saved / week</span>
                  <div class="mock__meter"><i style="width: 78%" /></div>
                </div>
                <div class="mock__stat">
                  <span>Tickets auto-resolved</span>
                  <div class="mock__meter"><i style="width: 64%" /></div>
                </div>
                <div class="mock__stat">
                  <span>Roadmap shipped</span>
                  <div class="mock__meter"><i style="width: 91%" /></div>
                </div>
              </div>
            )}
          </div>
        </li>
      ))
    }
  </ul>
</section>

<style>
  .services__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: clamp(4rem, 10vh, 7rem);
  }

  .feat {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: clamp(2rem, 6vw, 6rem);
  }

  .feat:nth-child(even) .feat__visual {
    order: -1;
  }

  .feat__text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.25rem;
    max-width: 30rem;
  }

  .feat__chip {
    border: 1px solid var(--c-line);
    background: var(--c-paper);
    padding: 0.5rem 1rem;
    border-radius: 99px;
    color: var(--c-ink-soft);
  }

  .feat__title {
    color: var(--c-ink);
  }

  .feat__body {
    color: var(--c-ink-soft);
    line-height: 1.65;
  }

  .feat__tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 0.5rem;
  }

  .feat__tags li {
    border: 1px solid var(--c-line);
    background: var(--c-paper);
    border-radius: 99px;
    padding: 0.45rem 0.9rem;
    color: var(--c-ink);
  }

  /* ---- mockup cards ---- */

  .mock {
    background: var(--c-paper);
    border: 1px solid var(--c-line);
    border-radius: 1.25rem;
    padding: clamp(1.25rem, 2.5vw, 2rem);
    box-shadow: 0 32px 64px -40px rgb(28 28 30 / 0.25);
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    min-height: 280px;
    justify-content: center;
  }

  .mock__bar {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--c-ink);
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--c-line);
  }

  .mock__row {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.8rem 0.9rem;
    border: 1px solid var(--c-line);
    border-radius: 0.75rem;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--c-ink);
  }

  .mock__row small {
    display: block;
    font-size: 0.72rem;
    color: var(--c-ink-soft);
    font-weight: 400;
  }

  .mock__row--hot {
    border-color: color-mix(in srgb, var(--c-accent) 35%, transparent);
    background: color-mix(in srgb, var(--c-accent) 5%, transparent);
  }

  .mock__check {
    flex: none;
    width: 1.1rem;
    height: 1.1rem;
    border: 1.5px solid var(--c-line);
    border-radius: 0.35rem;
  }

  .mock__check--done {
    background: var(--c-accent);
    border-color: var(--c-accent);
  }

  .mock--chat {
    align-items: center;
    text-align: center;
  }

  .mock__orb {
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 50%;
    background: radial-gradient(circle at 32% 30%, #ff9d6b, var(--c-accent) 58%, var(--c-accent-deep));
  }

  .mock__q {
    font-weight: 600;
    color: var(--c-ink);
  }

  .mock__input {
    width: 100%;
    border: 1px solid var(--c-line);
    border-radius: 99px;
    padding: 0.8rem 1.2rem;
    font-size: 0.85rem;
    color: var(--c-ink-soft);
    text-align: left;
  }

  .mock__type {
    display: inline-block;
    white-space: nowrap;
  }

  .mock__chips {
    display: flex;
    gap: 0.5rem;
  }

  .mock__chips span {
    font-size: 0.72rem;
    font-weight: 500;
    border: 1px solid var(--c-line);
    border-radius: 99px;
    padding: 0.35rem 0.8rem;
    color: var(--c-ink-soft);
  }

  .mock__dots {
    display: flex;
    gap: 0.4rem;
  }

  .mock__dots i {
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 50%;
    background: var(--c-line);
  }

  .mock__code {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    padding: 1rem 0;
  }

  .mock__code span {
    display: block;
    height: 0.55rem;
    border-radius: 99px;
    background: var(--c-bg);
  }

  .mock__code .mock__code--accent {
    background: color-mix(in srgb, var(--c-accent) 30%, var(--c-bg));
  }

  .mock__deploy {
    font-size: 0.78rem;
    font-weight: 500;
    color: #1d9e4b;
  }

  .mock__stat {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--c-ink);
  }

  .mock__meter {
    height: 0.55rem;
    border-radius: 99px;
    background: var(--c-bg);
    overflow: clip;
  }

  .mock__meter i {
    display: block;
    height: 100%;
    border-radius: 99px;
    background: var(--c-accent);
  }

  @media (max-width: 820px) {
    .feat {
      grid-template-columns: 1fr;
    }

    .feat:nth-child(even) .feat__visual {
      order: 0;
    }
  }
</style>
