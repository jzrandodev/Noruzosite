---
const services = [
  {
    n: "01",
    title: "AI Automation",
    blurb:
      "We find the busywork in your operation and delete it. Workflows that run themselves, around the clock, without the headcount.",
  },
  {
    n: "02",
    title: "Custom AI Agents",
    blurb:
      "Agents that live inside your tools — triaging, drafting, researching and acting. Built for your stack, tuned to your rules.",
  },
  {
    n: "03",
    title: "AI Product Builds",
    blurb:
      "From a napkin sketch to production. We design, prototype and ship AI-native products with real interfaces and real users.",
  },
  {
    n: "04",
    title: "AI Strategy",
    blurb:
      "A roadmap, not a buzzword deck. We audit what AI can actually do for your business and hand you a plan worth executing.",
  },
];
---

<section class="services section" id="services" data-theme-section="dark">
  <p class="services__label t-label" data-reveal>What we do</p>

  <ul class="services__list">
    {
      services.map((s) => (
        <li class="services__row" data-service-row data-hover>
          <span class="services__num t-label">{s.n}</span>
          <h2 class="services__title t-display t-display--lg">{s.title}</h2>
          <p class="services__blurb">{s.blurb}</p>
        </li>
      ))
    }
  </ul>
</section>

<style>
  .services__label {
    color: var(--c-accent-soft);
    margin-bottom: 3rem;
  }

  .services__list {
    list-style: none;
  }

  .services__row {
    position: relative;
    display: grid;
    grid-template-columns: 4rem 1fr minmax(16rem, 24rem);
    align-items: center;
    gap: 2rem;
    padding: 2.5rem 0;
    border-top: 1px solid color-mix(in srgb, var(--c-cream) 20%, transparent);
    transition: padding-left 0.45s var(--ease-out-expo);
  }

  .services__row:last-child {
    border-bottom: 1px solid color-mix(in srgb, var(--c-cream) 20%, transparent);
  }

  .services__row::before {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--c-accent);
    transform: scaleY(0);
    transform-origin: bottom;
    transition: transform 0.45s var(--ease-out-expo);
    z-index: -1;
  }

  .services__row:hover::before {
    transform: scaleY(1);
    transform-origin: top;
  }

  .services__row:hover {
    padding-left: 1.5rem;
    padding-right: 1.5rem;
  }

  .services__num {
    color: var(--c-accent-soft);
    transition: color 0.3s;
  }

  .services__row:hover .services__num {
    color: var(--c-black);
  }

  .services__title {
    color: var(--c-cream);
  }

  .services__blurb {
    color: color-mix(in srgb, var(--c-cream) 75%, transparent);
    transition: color 0.3s;
  }

  .services__row:hover .services__blurb {
    color: var(--c-black);
  }

  @media (max-width: 860px) {
    .services__row {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }
  }
</style>
