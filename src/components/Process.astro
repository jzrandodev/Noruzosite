---
import SectionHead from "./SectionHead.astro";

const steps = [
  {
    n: "01",
    title: "Analyze",
    blurb:
      "We dig into your workflows and flag the few places where AI genuinely pays off, with numbers attached.",
  },
  {
    n: "02",
    title: "Build",
    blurb:
      "We design and develop the automation or agent, tailored to your stack, your data and your rules.",
  },
  {
    n: "03",
    title: "Integrate",
    blurb:
      "We wire it into the tools you already use with minimal disruption, and train your team to run it.",
  },
  {
    n: "04",
    title: "Optimize",
    blurb:
      "We measure results, refine prompts and pipelines, and compound the gains month over month.",
  },
];
---

<section class="process section" id="process" data-theme-section="light">
  <SectionHead
    chip="Our process"
    title='Simple, smart and <em class="t-tilt">scalable</em>'
    sub="One loop, four moves: find the opportunity, build it, then compound it."
  />

  <div class="process__wrap">
    <span class="process__line" data-process-line aria-hidden="true"></span>
    <ol class="process__list" role="list">
      {
        steps.map((s) => (
          <li class="prow" data-service-row>
            <span class="prow__num t-tilt" aria-hidden="true">{s.n}</span>
            <h3 class="prow__title t-display t-display--md">{s.title}</h3>
            <p class="prow__body">{s.blurb}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .process__wrap {
    position: relative;
    padding-left: clamp(1.75rem, 4vw, 3.5rem);
  }

  .process__line {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--c-accent);
    transform-origin: top;
  }

  .process__list {
    list-style: none;
  }

  .prow {
    display: grid;
    grid-template-columns: 6rem 1fr minmax(16rem, 26rem);
    gap: 2rem;
    align-items: baseline;
    padding: clamp(2rem, 4vh, 3rem) 0;
    border-top: 1px solid var(--c-line);
  }

  .prow:last-child {
    border-bottom: 1px solid var(--c-line);
  }

  .prow__num {
    font-size: clamp(2.2rem, 4vw, 3.4rem);
    line-height: 1;
  }

  .prow__title {
    color: var(--c-ink);
  }

  .prow__body {
    color: var(--c-ink-soft);
    line-height: 1.65;
    font-size: 0.95rem;
  }

  @media (max-width: 860px) {
    .prow {
      grid-template-columns: 4rem 1fr;
    }

    .prow__body {
      grid-column: 2;
    }
  }
</style>
